{
  "name": "oxtro-ui",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "proto:gen": "buf generate .. --template buf.gen.yaml && bun run --cwd packages/proto generate:index"
  },
  "devDependencies": {
    "@bufbuild/buf": "^1.66.0",
    "@bufbuild/protoc-gen-es": "^2.11.0",
    "@connectrpc/protoc-gen-connect-es": "^1.7.0",
    "prettier": "^3.7.4",
    "shadcn-svelte": "^1.1.1",
    "turbo": "^2.8.11",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
