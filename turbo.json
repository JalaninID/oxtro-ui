{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env",
        ".env.local",
        ".env.production",
        ".env.production.local",
        "apps/*/.env",
        "apps/*/.env.local",
        "apps/*/.env.production",
        "apps/*/.env.production.local"
      ],
      "env": ["PUBLIC_API_BASE_URL", "PUBLIC_*"],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        ".svelte-kit/**",
        "build/**",
        "dist/**"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env",
        ".env.local",
        ".env.development",
        ".env.development.local",
        "apps/*/.env",
        "apps/*/.env.local",
        "apps/*/.env.development",
        "apps/*/.env.development.local"
      ],
      "env": ["PUBLIC_API_BASE_URL", "PUBLIC_*"]
    },
    "test": {
      "dependsOn": ["^test"],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env",
        ".env.local",
        ".env.development",
        ".env.development.local",
        "apps/*/.env",
        "apps/*/.env.local",
        "apps/*/.env.development",
        "apps/*/.env.development.local"
      ],
      "env": ["PUBLIC_API_BASE_URL", "PUBLIC_*"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env",
        ".env.local",
        ".env.development",
        ".env.development.local",
        "apps/*/.env",
        "apps/*/.env.local",
        "apps/*/.env.development",
        "apps/*/.env.development.local"
      ],
      "env": ["PUBLIC_API_BASE_URL", "PUBLIC_*"]
    }
  }
}
